# Requests de ejemplo para toda la API
# Compatible con la extensión "REST Client" de VS Code (humao.rest-client)
# y con IntelliJ/WebStorm. Ejecutá cada request con "Send Request".
#
# Tip: corré primero el seed (npx prisma db seed) y reemplazá los
# @authorId / @bookId con ids reales de tu base (los devuelve cualquier listado).

@baseUrl = http://localhost:8000
@authorId = REEMPLAZAR-CON-UUID-DE-AUTOR
@bookId = REEMPLAZAR-CON-UUID-DE-LIBRO

###############################################
# AUTORES
###############################################

### Crear un autor
POST {{baseUrl}}/authors
Content-Type: application/json

{
  "name": "Ursula K. Le Guin",
  "country": "United States"
}

### Crear un autor duplicado (debe devolver 409)
POST {{baseUrl}}/authors
Content-Type: application/json

{
  "name": "Ursula K. Le Guin"
}

### Listar autores (paginado)
GET {{baseUrl}}/authors?page=1&pageSize=10

### Buscar autores por nombre (parcial, case-insensitive)
GET {{baseUrl}}/authors?name=tolkien

### Detalle de un autor (incluye cantidad de libros)
GET {{baseUrl}}/authors/{{authorId}}

###############################################
# LIBROS
###############################################

### Crear un libro (los tags se crean o reutilizan, siempre en minúsculas)
POST {{baseUrl}}/books
Content-Type: application/json

{
  "authorId": "{{authorId}}",
  "title": "La mano izquierda de la oscuridad",
  "genre": "fiction",
  "tags": ["Sci-Fi", "classic"]
}

### Listar libros (defaults: page=1, limit=10, orden createdAt desc)
GET {{baseUrl}}/books

### Listar con filtros combinados
GET {{baseUrl}}/books?status=read&genre=fiction&minRating=4&sortBy=rating&order=desc&page=1&limit=10

### Filtrar por nombre de autor (parcial) y por tag
GET {{baseUrl}}/books?authorName=le guin&tag=classic

### Detalle de un libro (incluye autor y tags)
GET {{baseUrl}}/books/{{bookId}}

### Empezar a leer (genera entrada en el historial)
PATCH {{baseUrl}}/books/{{bookId}}
Content-Type: application/json

{
  "status": "reading"
}

### Terminar y calificar en un solo request
PATCH {{baseUrl}}/books/{{bookId}}
Content-Type: application/json

{
  "status": "read",
  "rating": 5
}

### Rating en un libro no leído (debe devolver 409)
PATCH {{baseUrl}}/books/{{bookId}}
Content-Type: application/json

{
  "rating": 3
}

### Reemplazar los tags de un libro
PATCH {{baseUrl}}/books/{{bookId}}
Content-Type: application/json

{
  "tags": ["favoritos", "releer"]
}

### Historial de cambios de status
GET {{baseUrl}}/books/{{bookId}}/history

### Soft delete (desaparece de listados y stats; 204 sin body)
DELETE {{baseUrl}}/books/{{bookId}}

###############################################
# ESTADÍSTICAS
###############################################

### Stats (agregaciones en DB; la 2ª llamada dentro del TTL sale del cache)
GET {{baseUrl}}/stats

###############################################
# CASOS DE ERROR
###############################################

### JSON malformado (debe devolver 400)
POST {{baseUrl}}/authors
Content-Type: application/json

{esto no es json

### Validación de Zod (debe devolver 422)
POST {{baseUrl}}/books
Content-Type: application/json

{
  "authorId": "no-es-un-uuid",
  "title": "",
  "genre": "poesia"
}

### Libro inexistente (debe devolver 404)
GET {{baseUrl}}/books/00000000-0000-0000-0000-000000000000
